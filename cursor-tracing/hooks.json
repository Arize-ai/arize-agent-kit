{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [{ "command": "bash .cursor/hooks/hook-handler.sh" }],
    "afterAgentResponse": [{ "command": "bash .cursor/hooks/hook-handler.sh" }],
    "afterAgentThought": [{ "command": "bash .cursor/hooks/hook-handler.sh" }],
    "beforeShellExecution": [{ "command": "bash .cursor/hooks/hook-handler.sh" }],
    "afterShellExecution": [{ "command": "bash .cursor/hooks/hook-handler.sh" }],
    "beforeMCPExecution": [{ "command": "bash .cursor/hooks/hook-handler.sh" }],
    "afterMCPExecution": [{ "command": "bash .cursor/hooks/hook-handler.sh" }],
    "beforeReadFile": [{ "command": "bash .cursor/hooks/hook-handler.sh" }],
    "afterFileEdit": [{ "command": "bash .cursor/hooks/hook-handler.sh" }],
    "stop": [{ "command": "bash .cursor/hooks/hook-handler.sh" }],
    "beforeTabFileRead": [{ "command": "bash .cursor/hooks/hook-handler.sh" }],
    "afterTabFileEdit": [{ "command": "bash .cursor/hooks/hook-handler.sh" }]
  }
}
