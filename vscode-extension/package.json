{
  "name": "arize-agent-kit",
  "displayName": "Arize Agent Kit",
  "description": "GUI install wizard and dashboard for Arize AI coding agent tracing",
  "version": "0.1.0",
  "publisher": "arize",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:arize-sidebar",
    "onCommand:arize.setup"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "arize.setup",
        "title": "Arize: Set Up Tracing"
      },
      {
        "command": "arize.reconfigure",
        "title": "Arize: Reconfigure Tracing"
      },
      {
        "command": "arize.startCollector",
        "title": "Arize: Start Collector"
      },
      {
        "command": "arize.stopCollector",
        "title": "Arize: Stop Collector"
      },
      {
        "command": "arize.statusBarMenu",
        "title": "Arize: Status Menu"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "arize",
          "title": "Arize Tracing",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "arize": [
        {
          "type": "webview",
          "id": "arize-sidebar",
          "name": "Arize Tracing"
        }
      ]
    }
  },
  "scripts": {
    "vscode:uninstall": "node ./dist/uninstall.js",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "yaml": "^2.3.0"
  }
}
