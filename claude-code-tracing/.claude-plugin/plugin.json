{
  "name": "claude-code-tracing",
  "description": "Automatic tracing of Claude Code sessions to Arize AX or Phoenix with OpenInference spans. Supports 9 hooks for comprehensive observability.",
  "version": "1.0.0",
  "author": {
    "name": "Arize AI",
    "email": "support@arize.com",
    "url": "https://arize.com"
  },
  "repository": "https://github.com/Arize-ai/arize-agent-kit",
  "license": "MIT",
  "keywords": [
    "tracing",
    "agents",
    "openinference",
    "arize",
    "phoenix",
    "claude-code"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "arize-hook-session-start"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "arize-hook-user-prompt-submit"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "arize-hook-pre-tool-use"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "arize-hook-post-tool-use"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "arize-hook-stop"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "arize-hook-subagent-stop"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "arize-hook-notification"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "arize-hook-permission-request"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "arize-hook-session-end"
          }
        ]
      }
    ]
  }
}
